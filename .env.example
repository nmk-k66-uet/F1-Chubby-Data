# Docker Compose environment variables
# Copy to .env and fill in values

# PostgreSQL (Cloud SQL)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=f1chubby
POSTGRES_USER=f1admin
POSTGRES_PASSWORD=

# InfluxDB
INFLUXDB_TOKEN=f1chubby-influx-token
INFLUXDB_PASSWORD=f1chubby2026

# Model Serving
USE_GCS=true
GCS_MODELS_BUCKET=f1chubby-model-gen-lang-client-0314607994

# Development mode (bypasses PG/InfluxDB, uses FastF1/Ergast fallbacks)
LOCAL_MODE=false
