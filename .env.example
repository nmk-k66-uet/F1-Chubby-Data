# Docker Compose environment variables
# Copy to .env and fill in values

# InfluxDB
INFLUXDB_TOKEN=f1chubby-influx-token
INFLUXDB_PASSWORD=f1chubby2026

# GCP Project
GCP_PROJECT_ID=<YOUR_PROJECT_ID>

# Model Serving
USE_GCS=true
GCS_MODELS_BUCKET=f1chubby-model-<PROJECT_ID>

# FastF1 Cache
GCS_CACHE_BUCKET=f1chubby-cache-<PROJECT_ID>

# Pub/Sub Subscriptions
TIMING_VIZ_SUB=f1-timing-viz-fast
RC_VIZ_SUB=f1-race-control-viz-fast
TIMING_PRED_SUB=f1-timing-pred-slow

# Gemini API (for tactical briefing)
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>

# F1 API Proxy (optional - Cloudflare Worker URL to bypass geo-blocking)
F1_API_PROXY=

# Development mode (bypasses InfluxDB, uses FastF1/Ergast fallbacks)
LOCAL_MODE=false
