# Docker Compose environment variables
# Copy to .env and fill in values

# InfluxDB
INFLUXDB_TOKEN=f1chubby-influx-token
INFLUXDB_PASSWORD=f1chubby2026

# Model Serving
USE_GCS=true
GCS_MODELS_BUCKET=f1chubby-model-<PROJECT_ID>

# Development mode (bypasses InfluxDB, uses FastF1/Ergast fallbacks)
LOCAL_MODE=false
